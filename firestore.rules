rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──
    match /users/{userId} {

      // Anyone can READ any user document (needed for leaderboards)
      allow read: if true;

      // Only the authenticated owner can WRITE their own document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Only the authenticated owner can DELETE their own document
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
